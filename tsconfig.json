{
  "compilerOptions": {
    "module": "es2020",
    "noImplicitAny": true,
    "target": "es2015",
    "lib": ["es2020"],
    "jsx": "react",
    "jsxFactory": "h",
    "strict": false,
    "sourceMap": true,
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "allowJs": true
  },
  "include": ["src/js/**/*.ts"],
  "exclude": ["src/js/journey-old.ts"]
}
